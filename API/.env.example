# ============================================================
# Infinite Canvas 配置模板
# 复制为 API/.env 后按需填写。所有端点/密钥不再有内置默认值，
# 留空即视为未配置，须在此本地填写。
# ============================================================

# ---- 出图接口（图像生成）----
IMAGE_API_BASE_URL=
IMAGE_API_KEY=
IMAGE_API_DEFAULT_MODEL=gpt-image-2
IMAGE_API_MODELS=gpt-image-2,nano-banana-pro

# ---- 对话接口（LLM）----
CHAT_API_BASE_URL=
CHAT_API_KEY=
CHAT_API_DEFAULT_MODEL=
CHAT_API_MODELS=

# ---- Comfly 兼容（可选，作为上面两者的回退）----
COMFLY_BASE_URL=
COMFLY_API_KEY=

# ---- ModelScope（可选）----
MODELSCOPE_API_KEY=
MODELSCOPE_CHAT_MODELS=Qwen/Qwen3-235B-A22B

# ---- ComfyUI（可选，本地/自建后端）----
COMFYUI_INSTANCES=
COMFY_ORG_API_KEY=
COMFY_ORG_FIREBASE_API_KEY=

# ============================================================
# 图床（VPS 部署必填：不落盘，图片全部上传图床）
# strategy: local=只存本地 / remote=只存图床(本地不留) / local_and_remote=两者都存
# VPS 部署请用 remote。目前图床类型仅支持兰空图床(lsky)。
# ============================================================
IMAGE_HOST_STRATEGY=remote
IMAGE_HOST_TYPE=lsky
IMAGE_HOST_BASE_URL=
IMAGE_HOST_USERNAME=
IMAGE_HOST_PASSWORD=
IMAGE_HOST_TOKEN=

# ---- 通用 ----
SYSTEM_PROMPT=You are a helpful assistant.
MAX_HISTORY_MESSAGES=0
REQUEST_TIMEOUT=120
IMAGE_POLL_INTERVAL=2
